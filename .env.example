# ==========================================================
# Laporta Scan · variables de entorno
# Copia este archivo a .env y rellena los valores.
# .env está en .gitignore — nunca se sube al repo.
# ==========================================================

# Puerto del servidor (Dokploy/Docker suelen inyectar PORT)
PORT=3000

# --- Google PageSpeed Insights (opcional pero recomendado) ---
# Sin esta key el scan funciona igual, pero SOLO muestra SEO + AEO/GEO
# (sin Performance / Core Web Vitals / Accesibilidad / Best Practices).
# Conseguir gratis en: https://console.cloud.google.com/apis/credentials
# (Activar "PageSpeed Insights API" · 25.000 requests/día gratis)
PSI_API_KEY=

# --- Dónde se guardan los leads ---
# Carpeta donde se escribe leads.jsonl. En Docker móntala como volumen
# persistente para que los leads sobrevivan a los redeploys.
DATA_DIR=./data

# --- (Opcional) Entrega de leads en tiempo real ---
# Si defines un webhook, cada lead se hace POST aquí además de guardarse en
# disco. Sirve para conectar Make / Zapier / n8n / un endpoint propio / Slack.
LEAD_WEBHOOK_URL=
